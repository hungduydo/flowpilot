# ─── LLM Provider ───
# Options: "ollama" (default), "anthropic", "openai"
LLM_PROVIDER=ollama

# ─── Ollama Cloud ───
# Get your API key from https://ollama.com/settings/keys
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=qwen3.5:397b
OLLAMA_API_KEY=your-ollama-cloud-api-key

# ─── Anthropic Claude (fallback provider) ───
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── OpenAI (optional — only needed if using OpenAI as provider) ───
# Local embeddings via all-MiniLM-L6-v2 are used by default, no OpenAI needed
OPENAI_API_KEY=sk-your-openai-api-key

# ─── n8n ───
# Get from n8n Settings > n8n API after first start
N8N_API_KEY=your-n8n-api-key

# ─── PostgreSQL ───
POSTGRES_USER=llmworkflow
POSTGRES_PASSWORD=llmworkflow123

# ─── App Settings ───
APP_ENV=development
LOG_LEVEL=debug
